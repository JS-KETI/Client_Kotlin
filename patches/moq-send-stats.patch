+/// Transport-level send statistics snapshot for the active QUIC connection.
+///
+/// Per-field `None` means the transport backend does not provide that metric.
+#[derive(uniffi::Record)]
+pub struct MoqSendStats {
+	/// Congestion-controller estimated send bandwidth, in bits per second.
+	pub estimated_send_rate_bps: Option<u64>,
+	/// Smoothed round-trip time estimate, in milliseconds.
+	pub rtt_ms: Option<u64>,
+	/// Total bytes sent on the connection (including retransmissions).
+	pub bytes_sent: Option<u64>,
+	/// Total number of datagrams detected as lost.
+	pub packets_lost: Option<u64>,
+}
