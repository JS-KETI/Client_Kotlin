+
+	/// Snapshot of transport send statistics for this session.
+	///
+	/// Returns `None` if the session handle is already dropped.
+	pub fn send_stats(&self) -> Option<MoqSendStats> {
+		let inner = self.inner.as_ref()?;
+		let stats = inner.stats();
+		Some(MoqSendStats {
+			estimated_send_rate_bps: stats.estimated_send_rate,
+			rtt_ms: stats.rtt.map(|d| d.as_millis() as u64),
+			bytes_sent: stats.bytes_sent,
+			packets_lost: stats.packets_lost,
+		})
+	}
 }
